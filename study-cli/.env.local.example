# Supabase project URL (same as the web app).
SUPABASE_URL=https://xxxxx.supabase.co

# Supabase anon key (optional, only for read-only fallback tests).
SUPABASE_ANON_KEY=

# Supabase service role key — NEVER commit. Grants the CLI bypass-RLS writes.
# Find it at: Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Access token for the official @supabase/mcp-server-supabase (personal access token,
# generate at https://supabase.com/dashboard/account/tokens).
SUPABASE_ACCESS_TOKEN=

# Your Supabase auth user id (uuid). The CLI writes all rows scoped to this user_id.
# Find it by signing into wonbee.kr/study, then running `select auth.uid();` in SQL Editor
# while logged in as the same user, or from Supabase Auth → Users tab.
CLI_USER_ID=
